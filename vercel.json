{
  "rewrites": [
    {
      "source": "/((?!sitemap.*\\.xml|robots\\.txt|favicon.*|.*\\.ico|.*\\.png|.*\\.jpg|.*\\.svg|assets/|_next/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap*(.*).xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}